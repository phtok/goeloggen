APP_ENV=dev
API_PORT=8000

# For docker-compose services.
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/portrait_generator
REDIS_URL=redis://redis:6379/0
QUEUE_NAME=portrait_jobs

STORAGE_BACKEND=local
STORAGE_ROOT=data/storage
STORAGE_PUBLIC_BASE_URL=/artifacts
R2_BUCKET=
R2_ENDPOINT_URL=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PREFIX=portrait-generator
R2_PUBLIC_BASE_URL=
R2_SIGNED_URL_EXPIRY_SECONDS=3600

MAX_UPLOAD_MB=20
RAW_IMAGE_RETENTION_DAYS=30
DEFAULT_ASPECT_RATIO=4:5
VARIANTS_PER_JOB=3

IDENTITY_THRESHOLD_DEFAULT=0.80
BRAND_THRESHOLD_DEFAULT=0.85
APPROVAL_MODE=single

AUTH_ENABLED=true
API_KEYS={"dev-editor-key":"editor","dev-brand-key":"brand_owner","dev-admin-key":"admin"}

MODEL_VERSION=sdxl_stub_v1
BRAND_PROFILE_VERSION=goe_brand_v1
BRAND_PROFILES_DIR=config/brand_profiles
FACE_DETECTOR_MODE=opencv
FACE_DETECTOR_MIN_CONFIDENCE=0.50

INFERENCE_BACKEND=stub
INFERENCE_FALLBACK_TO_STUB=true
DIFFUSERS_BASE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
DIFFUSERS_REFINER_MODEL=
DIFFUSERS_DEVICE=cuda
DIFFUSERS_DTYPE=float16
DIFFUSERS_NUM_INFERENCE_STEPS=35
DIFFUSERS_GUIDANCE_SCALE=6.5
DIFFUSERS_STRENGTH=0.42
DIFFUSERS_LORA_PATH=
DIFFUSERS_LORA_SCALE=0.8
FACEID_ADAPTER_PATH=
FACEID_ADAPTER_SUBFOLDER=
FACEID_WEIGHT_NAME=
FACEID_ENABLED=true

EXPORT_WEB_SIZE=1200x1500
EXPORT_PRINT_SIZE=3000x3750
